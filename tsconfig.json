{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": [
        "*"
      ]
    }
  },
  "include": ["src/**/*.ts","src/**/*.tsx","tools/**/*.ts","tools/**/*.js"],
  "exclude": ["node_modules","web","**/*.test.ts","**/*.test.tsx"]
}
