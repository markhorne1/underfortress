{
  "name": "underfortress",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "screenshots": "node tools/captureScreenshots.mjs",
    "screenshots:topnav": "node tools/captureTopNavScreenshots.mjs",
    "screenshots:all": "node tools/captureAllAreaScreenshots.mjs",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dist:win": "npm run build && electron-builder --win nsis portable"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zod": "^3.21.4",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "4.0.0",
    "babel-jest": "^29.6.1",
    "concurrently": "^9.2.1",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "jest": "^29.6.1",
    "playwright": "^1.58.2",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.2",
    "vite": "^4.2.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.markhorne.underfortress",
    "productName": "Underfortress",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
